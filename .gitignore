# ---- data: NOTHING under data/ gets committed ----
# (raw dumps, the parquet dataset, derived counts, reference caches -
#  all of it is regenerable via the scripts/notebooks)
# NOTE: 'data/*' (not 'data/') so git still DESCENDS into data/ and lets the
# reference-cache whitelist below take effect (a bare 'data/' blocks re-includes).
data/*
# keep only the documentation/placeholder files so a fresh clone
# still shows the expected folder structure:
!data/README.md
!data/processed/README.md
!data/raw/PUT_DATA_HERE.txt

# EXCEPTION: the reference cache the INTERNAL machine needs for the live
# append (aggregate_posts looks up the ticker universe + word-ticker
# screening here). These are public Nasdaq symbol lists + a derived
# case-ratio table - they hold NO post text, authors or ids, so they are
# safe to commit. The re-include-dir-then-re-exclude-contents pattern keeps
# the seen-ids ledger (a .json) private.
!data/reference/
data/reference/*
!data/reference/nasdaqlisted.txt
!data/reference/otherlisted.txt
!data/reference/ticker_classification.csv

# ---- ABSTRACTED_DATA: the ONE data folder that IS committed ----
# It holds only the five abstracted aggregates (daily counts + sentiment
# scores per ticker/theme) - NO post text, authors, ids or subreddits. See
# ABSTRACTED_DATA/README.md. Belt-and-suspenders: never let raw text or the
# local dedup ledger slip in even if a file lands here by mistake.
ABSTRACTED_DATA/*.jsonl
ABSTRACTED_DATA/*.zst
ABSTRACTED_DATA/*.json
ABSTRACTED_DATA/posts*.parquet
ABSTRACTED_DATA/*slice*.parquet
# (the live seen-ids ledger lives at data/reference/abstracted_live_meta.json,
#  which is already ignored by the data/ rule above - post ids stay private.)

# secrets - never commit session captures
curl.txt

# junk / regenerable
__pycache__/
.pytest_cache/
.DS_Store
.venv/
.ipynb_checkpoints/
*.bak
*.bak.parquet
notebooks/*.tmp.ipynb
notebooks/*.tune.ipynb
