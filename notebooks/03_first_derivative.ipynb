     ]
    }
   ],
   "source": [
    "# One figure per year: smoothed signal for the year's top 10 tickers,\n",
    "# with that year's inflection days marked as dots in the line's colour.\n",
    "YEARLY_TOP_N = 10\n",
    "\n",
    "daily['year'] = daily['date'].dt.year\n",
    "\n",
    "for year in sorted(daily['year'].unique()):\n",
    "    year_df = daily[daily['year'] == year]\n",
    "    totals = year_df.groupby('ticker')[VALUE_COLUMN].sum().sort_values(ascending=False)\n",
    "    top = list(totals.head(YEARLY_TOP_N).index)\n",
    "    if not top:\n",
    "        continue\n",
    "\n",
    "    plt.figure(figsize=(13, 6))\n",
    "    for ticker in top:\n",
    "        series = build_daily_series(year_df, ticker, value_col=VALUE_COLUMN)\n",
    "        if series is None:\n",
    "            continue\n",
    "        result = compute_inflection(series, SMOOTH, K)   # threshold = THIS year's noise\n",
    "        line, = plt.plot(result.index, result['smoothed'], linewidth=1.5, label=ticker)\n",
    "        flags = result[result['is_inflection']]\n",
    "        plt.scatter(flags.index, flags['smoothed'], color=line.get_color(), s=35, zorder=5)\n",
    "\n",
    "    plt.title(f'{year} - top {len(top)} tickers by {VALUE_COLUMN} (dots = take-off days)')\n",
    "    plt.xlabel('date'); plt.ylabel(f'smoothed {VALUE_COLUMN}')\n",
    "    plt.legend(bbox_to_anchor=(1.01, 1), loc='upper left')\n",
    "    plt.grid(True, alpha=0.3); plt.tight_layout()\n",
    "    plt.show()"
   ]
