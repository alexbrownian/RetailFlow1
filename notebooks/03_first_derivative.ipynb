    "ROOT = os.path.dirname(os.getcwd()) if os.path.basename(os.getcwd()) == 'notebooks' else os.getcwd()\n",
    "sys.path.insert(0, ROOT)\n",
    "print('project root:', ROOT)"
   ]
  },
